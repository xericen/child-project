.container
  .login-wrap

    //- 로딩
    div(*ngIf="pageLoading", class="loading-wrap")
      .spinner
      p 식단 불러오는 중...

    //- 본문
    div(*ngIf="!pageLoading")
      .header-row
        span.btn-back('(click)'="goBack()") ← 뒤로

      .title-row
        h1.title 오늘의 식단 🍽️
        button.btn-dinner(*ngIf="role === 'parent'",
          '(click)'="onDinnerClick()",
          '[disabled]'="dinnerLoading",
          '[class.active]'="analysis") 저녁 추천

      //- 분석 전: 타임라인 식단 표시
      div(*ngIf="!analysis && !dinnerLoading")
        .timeline
          //- 오전간식
          .tl-block(*ngIf="morningSnack",
            '[class.allergy-danger]'="role === 'parent' && hasAllergyWarning('오전간식')")
            .tl-dot
            .tl-label 오전간식
            .tl-card
              .tl-content('[innerHTML]'="formatMealContent(morningSnack)")
              .allergy-inline(*ngIf="role === 'parent' && hasAllergyWarning('오전간식')")
                | ⚠️ {{ getAllergyText('오전간식') }}

          //- 점심
          .tl-block(*ngIf="lunchMenu",
            '[class.allergy-danger]'="role === 'parent' && hasAllergyWarning('점심')")
            .tl-dot
            .tl-label 점심
            .tl-card
              .tl-content('[innerHTML]'="formatMealContent(lunchMenu)")
              .allergy-inline(*ngIf="role === 'parent' && hasAllergyWarning('점심')")
                | ⚠️ {{ getAllergyText('점심') }}

          //- 오후간식
          .tl-block(*ngIf="afternoonSnack",
            '[class.allergy-danger]'="role === 'parent' && hasAllergyWarning('오후간식')")
            .tl-dot
            .tl-label 오후간식
            .tl-card
              .tl-content('[innerHTML]'="formatMealContent(afternoonSnack)")
              .allergy-inline(*ngIf="role === 'parent' && hasAllergyWarning('오후간식')")
                | ⚠️ {{ getAllergyText('오후간식') }}

          //- 빈 상태
          .empty-state(*ngIf="!morningSnack && !lunchMenu && !afternoonSnack")
            span.empty-icon 🍽️
            p 오늘 등록된 식단이 없습니다.

        //- 식단표 등록 칼로리/단백질 (HWP 값)
        .db-nutrition-bar(*ngIf="dbKcal > 0")
          .db-nutrition-item
            span.db-label 칼로리
            span.db-value {{ dbKcal }}
            span.db-unit kcal
          .db-nutrition-item
            span.db-label 단백질
            span.db-value {{ dbProtein }}
            span.db-unit g

      //- 분석 로딩
      .dinner-loading-wrap(*ngIf="dinnerLoading")
        .spinner
        span 식단 영양소를 분석하고 있어요...

      //- 분석 완료: 3페이지 캐러셀
      div(*ngIf="analysis && !dinnerLoading")

        //- 페이지 1: 타임라인 + 개별 칼로리
        div(*ngIf="currentPage === 0")
          .timeline
            .tl-block(*ngFor="let meal of analysis.stage1?.meals || []",
              '[class.allergy-danger]'="role === 'parent' && hasAllergyWarning(meal.meal_type)")
              .tl-dot
              .tl-label {{ meal.meal_type }}
              .tl-card
                .food-row(*ngFor="let item of meal.items || []",
                  '[class.substitute]'="item.is_substitute")
                  span.food-name {{ item.name }}
                  span.food-kcal {{ item.calories }} kcal
                .kcal-row
                  span.kcal-label 소계
                  span.kcal-val {{ meal.subtotal?.calories || 0 }} kcal
                .allergy-inline(*ngIf="role === 'parent' && hasAllergyWarning(meal.meal_type)")
                  | ⚠️ {{ getAllergyText(meal.meal_type) }}

          //- 하단 요약
          .summary-card
            .summary-title 오늘 총 섭취 요약 · {{ analysis?.stage2?.age >= 3 ? '3~5세' : '1~2세' }} 기준
            .summary-row
              .summary-item
                .lbl 칼로리
                .val {{ dbKcal || analysis.stage1.total.calories || 0 }}
                  span.unit kcal
              .summary-item
                .lbl 단백질
                .val {{ dbProtein || analysis.stage1.total.protein || 0 }}
                  span.unit g
              .summary-item
                .lbl 칼슘
                .val {{ analysis.stage1.total.calcium || 0 }}
                  span.unit mg
              .summary-item
                .lbl 철분
                .val {{ analysis.stage1.total.iron || 0 }}
                  span.unit mg
            .progress-wrap
              .progress-label-row
                span 칼로리 달성률
                span {{ dbKcal || analysis.stage1.total.calories || 0 }} / {{ analysis.stage2?.recommended?.calories || '—' }} kcal
              .progress-bar
                .progress-fill('[style.width.%]'="getNutrientFillPercent('calories')")

          .page-nav
            .dots
              span.dot-ind.active
              span.dot-ind
              span.dot-ind
            button.next-btn('(click)'="goToPage(1)")
              | 영양 자세히 보기
              svg(width="14", height="14", viewBox="0 0 16 16", fill="none", stroke="currentColor", stroke-width="1.5")
                path(d="M6 4l4 4-4 4")

        //- 페이지 2: 영양소 카드 그리드
        div(*ngIf="currentPage === 1")
          .nutrient-card
            h2.nutrient-title 오늘 섭취 영양소
            p.nutrient-sub 식약처 DB 기반 · {{ analysis?.stage2?.age >= 3 ? '3~5세' : '1~2세' }} 기준

            .nutrient-grid
              .nutrient-box(*ngFor="let key of nutrientKeys()",
                '[class.n-low]'="getNutrientStatus(key) === '부족'",
                '[class.n-over]'="getNutrientStatus(key) === '초과'",
                '[class.n-ok]'="getNutrientStatus(key) === '적정'")
                span.nb-label {{ getNutrientLabel(key) }}
                .nb-value
                  strong {{ analysis?.stage2?.consumed?.[key] || 0 }}
                  span {{ getNutrientUnit(key) }}
                .nb-bar
                  .nb-fill('[style.width.%]'="getNutrientFillPercent(key)")
                span.status-badge.badge-warn(*ngIf="getNutrientStatus(key) === '부족'") 부족 (목표 {{ analysis?.stage2?.recommended?.[key] || 0 }})
                span.status-badge.badge-over(*ngIf="getNutrientStatus(key) === '초과'") +{{ analysis?.stage2?.surplus?.[key] || 0 }}{{ getNutrientUnit(key) }} 초과
                span.status-badge.badge-good(*ngIf="getNutrientStatus(key) === '적정'") 적정

          .page-nav
            button.prev-btn('(click)'="goToPage(0)")
              svg(width="14", height="14", viewBox="0 0 16 16", fill="none", stroke="currentColor", stroke-width="1.5")
                path(d="M10 4L6 8l4 4")
              | 식단 보기
            .dots
              span.dot-ind
              span.dot-ind.active
              span.dot-ind
            button.next-btn('(click)'="goToPage(2)")
              | 저녁 추천 보기
              svg(width="14", height="14", viewBox="0 0 16 16", fill="none", stroke="currentColor", stroke-width="1.5")
                path(d="M6 4l4 4-4 4")

        //- 페이지 3: 저녁 추천
        div(*ngIf="currentPage === 2")
          .recommend-card
            h2.rec-title 저녁 메뉴 추천

            //- 칼로리 진행률
            .calorie-progress-section
              .calorie-progress-label 하루 권장 칼로리 섭취율
              .calorie-ring-wrap
                svg(viewBox="0 0 120 120", width="120", height="120")
                  circle.calorie-ring-bg(cx="60", cy="60", r="48")
                  circle.calorie-ring-fill(cx="60", cy="60", r="48",
                    '[attr.stroke-dasharray]'="getCalorieRingCircumference()",
                    '[attr.stroke-dashoffset]'="getCalorieRingOffset()",
                    transform="rotate(-90 60 60)")
                .calorie-ring-text
                  span.ring-percent {{ getDailyCaloriePercent() }}%
                  span.ring-sub 섭취 완료
              .calorie-deficit-text(*ngIf="getDailyCalorieDeficit() > 0")
                | 저녁에 {{ getDailyCalorieDeficit() }}kcal 더 필요해요
              .calorie-deficit-text.surplus(*ngIf="getDailyCalorieDeficit() <= 0")
                | 오늘 칼로리를 충분히 섭취했어요 👍

            .rec-menu-box
              .rec-menu-header 추천 메뉴
              .rec-menu-row(*ngFor="let menu of analysis.stage3?.menus || []")
                span.rec-name {{ menu.name }}
                span.rec-kcal +{{ menu.nutrients?.calories || 0 }} kcal

            .ingredient-section(*ngIf="mainIngredients?.length")
              .ingredient-title 오늘 식단 주재료
              .ingredient-tags
                span.ingredient-tag(*ngFor="let ing of mainIngredients",
                  '[class.allergen]'="ing.isAllergen") {{ ing.name }}

          .page-nav
            button.prev-btn('(click)'="goToPage(1)")
              svg(width="14", height="14", viewBox="0 0 16 16", fill="none", stroke="currentColor", stroke-width="1.5")
                path(d="M10 4L6 8l4 4")
              | 영양소 보기
            .dots
              span.dot-ind
              span.dot-ind
              span.dot-ind.active
            .spacer

      //- 에러
      .dinner-error(*ngIf="dinnerError && !dinnerLoading")
        | {{ dinnerError }}
