.container
  .login-wrap

    .header-row
      button.back-btn('(click)'="goBack()") ← 돌아가기
      button.edit-btn(*ngIf="!isEditing",
        '(click)'="startEdit()") 편집

    h1.title 회원정보

    //- 부모: 탭 바 (회원정보 / 알레르기)
    .tab-bar(*ngIf="role === 'parent'")
      span.tab-item([class.active]="activeTab === 'info'",
        '(click)'="switchTab('info')") 회원정보
      span.tab-item([class.active]="activeTab === 'allergy'",
        '(click)'="switchTab('allergy')") 알레르기 정보

    //- ===== 회원정보 탭 =====
    div(*ngIf="activeTab === 'info'")

      //- 서버 회원 코드 (원장만, 항상 읽기 전용)
      .form-group(*ngIf="role === 'director' && serverCode")
        label.form-label 서버 회원 코드
        .input-wrap
          input.form-input(type="text",
            [value]="serverCode",
            readonly,
            style="letter-spacing: 2px; font-weight: 700;")

      //- 이메일 (항상 읽기 전용)
      .form-group
        label.form-label 이메일
        .input-wrap
          input.form-input(type="text",
            [value]="email",
            readonly)

      //- 역할
      .form-group
        label.form-label 역할
        .input-wrap
          input.form-input(type="text",
            [value]="role === 'parent' ? '부모' : role === 'teacher' ? '교사' : role === 'director' ? '원장' : role",
            readonly)

      //- 이름
      .form-group
        label.form-label 이름
        .input-wrap
          input.form-input(*ngIf="!isEditing",
            type="text",
            [value]="nickname",
            readonly)
          input.form-input(*ngIf="isEditing",
            type="text",
            placeholder="이름을 입력해주세요",
            [(ngModel)]="nickname")

      //- 전화번호
      .form-group
        label.form-label 전화번호
        .input-wrap
          input.form-input(*ngIf="!isEditing",
            type="text",
            [value]="phone || '미등록'",
            readonly)
          input.form-input(*ngIf="isEditing",
            type="tel",
            placeholder="010-0000-0000",
            [(ngModel)]="phone",
            '(ngModelChange)'="formatPhone()")

      //- 부모 전용: 자녀 정보
      div(*ngIf="role === 'parent'")
        .form-group
          label.form-label 자녀 이름
          .input-wrap
            input.form-input(type="text",
              [value]="childName",
              readonly)

        .form-group
          label.form-label 생년월일
          .input-wrap
            input.form-input(*ngIf="!isEditing",
              type="text",
              [value]="birthDate",
              readonly)
            input.form-input(*ngIf="isEditing",
              type="date",
              [(ngModel)]="birthDate")

        .form-group
          label.form-label 쌍둥이 여부
          div(*ngIf="!isEditing")
            .input-wrap
              input.form-input(type="text",
                [value]="twinType",
                readonly)
          .twin-options(*ngIf="isEditing")
            button.twin-btn(*ngFor="let opt of twinOptions",
              [class.active]="twinType === opt",
              '(click)'="selectTwin(opt)") {{ opt }}

      //- 편집 모드 버튼
      .btn-row(*ngIf="isEditing")
        button.cancel-btn('(click)'="cancelEdit()") 취소
        button.save-btn('(click)'="saveMyInfo()") 저장

      //- 비밀번호 변경 섹션
      .section-divider
      .password-change-section
        button.pw-toggle-btn('(click)'="togglePasswordChange()")
          | {{ showPasswordChange ? '비밀번호 변경 닫기' : '🔒 비밀번호 변경' }}

        div(*ngIf="showPasswordChange")
          .form-group
            label.form-label 현재 비밀번호
            .input-wrap
              input.form-input(type="password",
                placeholder="현재 비밀번호",
                [(ngModel)]="currentPassword")
          .form-group
            label.form-label 새 비밀번호
            .input-wrap
              input.form-input(type="password",
                placeholder="새 비밀번호 (4자 이상)",
                [(ngModel)]="newPassword")
          .form-group
            label.form-label 비밀번호 확인
            .input-wrap
              input.form-input(type="password",
                placeholder="새 비밀번호 확인",
                [(ngModel)]="confirmPassword")
          .btn-row
            button.cancel-btn('(click)'="togglePasswordChange()") 취소
            button.save-btn('(click)'="changePassword()") 변경

    //- ===== 알레르기 탭 (부모만) =====
    div(*ngIf="activeTab === 'allergy' && role === 'parent'")

      div(*ngIf="!isEditing")
        .allergy-summary
          .allergy-summary-title 등록된 알레르기
          .allergy-tag-list
            ng-container(*ngFor="let a of standardAllergies")
              span.allergy-tag(*ngIf="a.checked") {{ a.icon }} {{ a.name }}
            span.allergy-tag(*ngIf="otherAllergy") 기타: {{ otherAllergy }}
            span.no-allergy(*ngIf="!hasAnyAllergy") 등록된 알레르기가 없습니다.
          .info-row(*ngIf="isSevere")
            span.info-label 중증 알레르기
            span.info-value.active 예
          .info-row(*ngIf="needsSubstitute")
            span.info-label 대체식 필요
            span.info-value.active 예
          .btn-row
            button.save-btn('(click)'="startEdit()") 알레르기 수정

      div(*ngIf="isEditing")
        p.form-hint 알레르기 항목을 선택해주세요.
        .allergy-grid
          .allergy-card(*ngFor="let item of standardAllergies",
            [class.selected]="item.checked",
            '(click)'="toggleStandardAllergy(item)")
            .allergy-card-icon {{ item.icon }}
            .allergy-card-name {{ item.name }}
            .allergy-card-desc {{ item.desc }}
            .allergy-card-check
              span(*ngIf="item.checked") ✓

        .form-group
          label.form-label 기타 알레르기
          p.form-hint 19종에 포함되지 않는 알레르기 (콤마로 구분)
          .input-wrap
            input.form-input(type="text",
              placeholder="예: 감자, 망고",
              [(ngModel)]="otherAllergy")

        .toggle-group
          .toggle-row('(click)'="toggleSevere()")
            span.toggle-label 중증 알레르기
            span.toggle-switch([class.on]="isSevere")
              span.toggle-knob

          .toggle-row('(click)'="toggleSubstitute()")
            span.toggle-label 대체식 필요
            span.toggle-switch([class.on]="needsSubstitute")
              span.toggle-knob

        .btn-row
          button.cancel-btn('(click)'="cancelEdit()") 취소
          button.save-btn('(click)'="saveMyInfo()") 저장
