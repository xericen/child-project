.container
  .login-wrap

    h1.title
      | child
      br
      | 참여하기

    .saved-servers(*ngIf="savedServers.length > 0")
      p.saved-title 이전에 참여한 어린이집
      .server-card(*ngFor="let s of savedServers; let i = index",
        '(click)'="joinSavedServer(s)")
        .server-card-icon 🏫
        .server-card-info
          .server-card-name {{ s.name }}
          .server-card-code {{ s.code }}
        button.server-card-remove(type="button",
          '(click)'="removeSavedServer($event, i)") ✕

      .divider-row
        .divider-line

    .form-group
      label.form-label 서버 회원번호
      .input-wrap('[class.error]'="errorMessage.length > 0")
        input.form-input(type="text",
          placeholder="서버 코드를 입력하세요",
          [(ngModel)]="serverCode",
          '(input)'="onInput()",
          maxlength="8",
          style="text-transform: uppercase; letter-spacing: 2px; font-weight: 700;")

    p.error-msg(*ngIf="errorMessage.length > 0") {{ errorMessage }}

    .btn-row
      a.btn-back('(click)'="goBack()") ← 돌아가기
      .btn-right
        span.btn-text 참여
        button.btn-circle(type="button",
          '[disabled]'="serverCode.length === 0",
          '(click)'="verifyCode()") →
