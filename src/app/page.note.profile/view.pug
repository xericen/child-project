.container
  .login-wrap

    //- 헤더
    .header-row
      span.btn-back('(click)'="goBack()")
        svg(width="20", height="20", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2")
          path(d="M15 18l-6-6 6-6")
      span.page-title(*ngIf="role === 'director'") 프로필
      span.page-title(*ngIf="role === 'teacher'") 아이 프로필
      span.header-placeholder

    //- 반별 탭 바
    .tab-bar(*ngIf="tabNames.length > 0")
      span.tab-item(*ngFor="let tab of tabNames",
        [class.active]="selectedTab === tab",
        '(click)'="selectTab(tab)") {{ tab }}

    //- 검색 입력
    .search-box
      .search-input-wrap
        svg.search-icon(width="16", height="16", viewBox="0 0 24 24", fill="none", stroke="#999", stroke-width="2")
          circle(cx="11", cy="11", r="8")
          path(d="M21 21l-4.35-4.35")
        input.search-input(type="text",
          placeholder="이름으로 검색...",
          '[(ngModel)]'="searchText",
          '(input)'="onSearch()")

    //- 원장 뷰: 선택된 탭의 교사 + 어린이
    div(*ngIf="role === 'director' && selectedTab !== '전체' && currentClass")
      .section-header
        .section-label
          span.section-icon 🏫
          span {{ currentClass.class_name }}
        span.btn-delete-class('(click)'="deleteClass(currentClass.class_name)",
          title="반 전체 삭제") ✕

    //- 원장 교사 목록
    div(*ngIf="role === 'director' && (currentClass || selectedTab === '전체')")
      .profile-list(*ngIf="filteredTeachers.length > 0")
        .profile-item(*ngFor="let teacher of filteredTeachers")
          .item-main
            .item-avatar
              span.avatar-icon 👩‍🏫
            .item-info
              .item-name {{ teacher.name }}
              .item-badge(*ngIf="selectedTab === '전체' && teacher.class_name") {{ teacher.class_name }}
            .item-actions
              button.btn-toggle('(click)'="toggleDetail(teacher)",
                '[class.open]'="teacher.showDetail")
                svg(width="16", height="16", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2")
                  path(d="M6 9l6 6 6-6")
              span.btn-delete('(click)'="deleteTeacher(teacher)") ✕

          .item-detail(*ngIf="teacher.showDetail")
            .detail-row
              span.detail-label 전화번호
              span.detail-value {{ teacher.phone || '미등록' }}

      //- 원장 어린이 목록
      .profile-list(*ngIf="filteredChildren.length > 0")
        .profile-item(*ngFor="let child of filteredChildren")
          .item-main
            .item-avatar.clickable(*ngIf="child.id",
              '(click)'="triggerChildPhotoUpload(child)",
              title="사진 변경")
              img.avatar-photo(*ngIf="child.profile_photo",
                [src]="getProfilePhotoUrl(child.profile_photo)",
                alt="프로필")
              span.avatar-icon(*ngIf="!child.profile_photo") 👶
              span.avatar-edit-badge 📷
            .item-avatar(*ngIf="!child.id")
              span.avatar-icon 👶
            .item-info
              .item-name
                | {{ child.name }}
                span.birthday-icon(*ngIf="child.is_birthday") 🎂
              .item-sub {{ child.nickname }}
              .item-badge(*ngIf="selectedTab === '전체' && child.class_name") {{ child.class_name }}
            .item-actions
              button.btn-toggle(*ngIf="child.has_childcheck",
                '(click)'="toggleDetail(child)",
                '[class.open]'="child.showDetail")
                svg(width="16", height="16", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2")
                  path(d="M6 9l6 6 6-6")
              span.text-muted(*ngIf="!child.has_childcheck") 미완료
              span.btn-delete('(click)'="deleteChild(child)") ✕

          .item-detail(*ngIf="child.showDetail && child.has_childcheck")
            .detail-row
              span.detail-label 부모 이름
              span.detail-value {{ child.parent_name || '-' }}
            .detail-row
              span.detail-label 전화번호
              span.detail-value {{ child.parent_phone || '-' }}
            .detail-row
              span.detail-label 쌍둥이
              span.detail-value {{ child.twin_type }}
            .detail-row
              span.detail-label 알레르기
              span.detail-value {{ getAllergies(child) }}
            .detail-row(*ngIf="child.is_severe")
              span.detail-label 중증 알레르기
              span.detail-value.warn 예
            .detail-row(*ngIf="child.needs_substitute")
              span.detail-label 대체식 필요
              span.detail-value.warn 예

    //- 교사 뷰
    div(*ngIf="role === 'teacher'")
      .profile-list(*ngIf="filteredChildren.length > 0")
        .profile-item(*ngFor="let child of filteredChildren")
          .item-main
            .item-avatar.clickable(*ngIf="child.id",
              '(click)'="triggerChildPhotoUpload(child)",
              title="사진 변경")
              img.avatar-photo(*ngIf="child.profile_photo",
                [src]="getProfilePhotoUrl(child.profile_photo)",
                alt="프로필")
              span.avatar-icon(*ngIf="!child.profile_photo") 👶
              span.avatar-edit-badge 📷
            .item-avatar(*ngIf="!child.id")
              span.avatar-icon 👶
            .item-info
              .item-name
                | {{ child.name }}
                span.birthday-icon(*ngIf="child.is_birthday") 🎂
              .item-sub {{ child.nickname }}
              .item-badge(*ngIf="child.class_name") {{ child.class_name }}
            .item-actions
              button.btn-toggle(*ngIf="child.has_childcheck",
                '(click)'="toggleDetail(child)",
                '[class.open]'="child.showDetail")
                svg(width="16", height="16", viewBox="0 0 24 24", fill="none", stroke="currentColor", stroke-width="2")
                  path(d="M6 9l6 6 6-6")
              span.text-muted(*ngIf="!child.has_childcheck") 미완료

          .item-detail(*ngIf="child.showDetail && child.has_childcheck")
            .detail-row
              span.detail-label 부모 이름
              span.detail-value {{ child.parent_name || '-' }}
            .detail-row
              span.detail-label 전화번호
              span.detail-value {{ child.parent_phone || '-' }}
            .detail-row
              span.detail-label 쌍둥이
              span.detail-value {{ child.twin_type }}
            .detail-row
              span.detail-label 알레르기
              span.detail-value {{ getAllergies(child) }}
            .detail-row(*ngIf="child.is_severe")
              span.detail-label 중증 알레르기
              span.detail-value.warn 예
            .detail-row(*ngIf="child.needs_substitute")
              span.detail-label 대체식 필요
              span.detail-value.warn 예

    .empty-state(*ngIf="role === 'director' && classes.length === 0")
      .empty-icon 📋
      p 등록된 프로필이 없습니다.

    .empty-state(*ngIf="role === 'teacher' && children.length === 0")
      .empty-icon 📋
      p 등록된 프로필이 없습니다.

    //- 숨겨진 파일 인풋
    input(#childPhotoInput="",
      type="file",
      accept="image/*",
      style="display:none",
      '(change)'="onChildPhotoSelected($event)")
